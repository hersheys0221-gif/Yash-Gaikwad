from collections import deque

class Queue:
    def __init__(self):
        self.q = deque()

    def enqueue(self, item):
        self.q.append(item)

    def safe_dequeue(self):
        if len(self.q) == 0:
            print("Queue is empty, cannot dequeue.")
            return None
        return self.q.popleft()


# Example
q = Queue()
q.enqueue(1)
q.enqueue(2)

print(q.safe_dequeue())  # 1
print(q.safe_dequeue())  # 2
print(q.safe_dequeue())  # empty case
