class Stack:
    def __init__(self):
        self.data = []

    def push(self, item):
        self.data.append(item)

    def safe_pop(self):
        if len(self.data) == 0:
            print("Stack is empty, nothing to pop.")
            return None
        return self.data.pop()


# Example
s = Stack()
s.push(10)
s.push(20)

print(s.safe_pop())  # 20
print(s.safe_pop())  # 10
print(s.safe_pop())  # empty case
